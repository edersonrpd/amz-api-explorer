# TikTok Shop Partner API credentials.
# O app_key e o app_secret vivem SOMENTE no backend e nunca sao expostos ao
# frontend. O app_secret e usado para assinar (HMAC-SHA256) cada requisicao.
TIKTOK_APP_KEY="MY_TIKTOK_APP_KEY"
TIKTOK_APP_SECRET="MY_TIKTOK_APP_SECRET"

# Base URL da Open API do TikTok Shop (global/ROW). Normalmente nao precisa mudar.
TIKTOK_BASE_URL="https://open-api.tiktokglobalshop.com"

# APP_URL: URL onde a aplicacao esta hospedada (links self-referential / callback).
APP_URL="MY_APP_URL"
